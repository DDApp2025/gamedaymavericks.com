# Gemfile for OPTIONAL local preview only.
# GitHub Pages builds the site for you, so you do NOT need Ruby/Jekyll
# installed to deploy. This file just lets you run the site locally.
#
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve
#
source "https://rubygems.org"

# Matches the Jekyll version and plugins GitHub Pages runs server-side.
gem "github-pages", group: :jekyll_plugins

# Required to run `jekyll serve` on Ruby 3.0+ (no longer bundled with Ruby).
gem "webrick", "~> 1.8"
